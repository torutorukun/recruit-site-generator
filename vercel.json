{
  "functions": {
    "api/analyze.js": { "maxDuration": 60 },
    "api/generate-site.js": { "maxDuration": 60 },
    "api/publish-site.js": { "maxDuration": 60 },
    "api/view-site.js": { "maxDuration": 30 }
  },
  "rewrites": [
    {
      "source": "/((?!api|admin).*)",
      "destination": "/api/view-site",
      "has": [{ "type": "host", "value": "recruit.xstagram.co.jp" }]
    }
  ]
}
