{
  "functions": {
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/generate-site.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/publish-site.js": {
      "maxDuration": 60
    },
    "api/upload-photo.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/view-site",
      "has": [
        {
          "type": "host",
          "value": "recruit.xstagram.co.jp"
        }
      ]
    }
  ]
}